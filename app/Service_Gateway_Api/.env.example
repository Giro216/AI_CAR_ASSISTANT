# Gateway listens on HOST:PORT
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000

# JSON map: path prefix -> service base url
# Order doesn't matter; the gateway matches the LONGEST prefix.
# Example: route car-catalog API to a separate service running on 8001
GATEWAY_ROUTES={"/api/v1/cars":"http://localhost:8001"}

# Optional: allow cross-origin requests (comma-separated origins). Leave empty to disable CORS.
GATEWAY_CORS_ORIGINS=
